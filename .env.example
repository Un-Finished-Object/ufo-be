# Local runtime profile
SPRING_PROFILES_ACTIVE=dev

# Docker Compose host port bindings
BACKEND_HOST_PORT=8080
MYSQL_HOST_PORT=3306

# MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ufo?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=ufo
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=ufo
MYSQL_USER=ufo
MYSQL_PASSWORD=change-me

# JWT
# Base64로 인코딩한 32바이트 이상의 비밀값을 사용합니다.
SPRING_JWT_SECRET=replace-with-a-base64-encoded-secret-at-least-32-bytes
SPRING_JWT_ACCESS_TOKEN_EXPIRE=7200000
SPRING_JWT_REFRESH_TOKEN_EXPIRE=1209600000

# OAuth2 client credentials
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=replace-with-google-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_ID=replace-with-kakao-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_SECRET=replace-with-kakao-client-secret
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_NAVER_CLIENT_ID=replace-with-naver-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_NAVER_CLIENT_SECRET=replace-with-naver-client-secret

# Application URLs
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback
OAUTH_SIGNUP_REDIRECT_URL=http://localhost:3000/auth/signup
OAUTH_COOKIE_DOMAIN=localhost
DOMAIN_URL=http://localhost:3000

# Referral
REFERRAL_HMAC_SECRET=replace-with-a-secret-at-least-32-characters

# Image/S3
CDN_BASE_URL=http://localhost:8080/images
DEFAULT_PROFILE_IMAGE_KEY=defaults/profile.png
S3_IMAGE_BUCKET=replace-with-s3-bucket-name
S3_REGION=ap-northeast-2
S3_PUBLIC_BASE_URL=https://replace-with-s3-bucket-name.s3.ap-northeast-2.amazonaws.com
